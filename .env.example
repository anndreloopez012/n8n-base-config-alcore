# ============================================================
# n8n-base-config-alcore
# Entorno local para estudiantes
# ============================================================

# Zona horaria
TZ=America/Guatemala
GENERIC_TIMEZONE=America/Guatemala

# PostgreSQL local
POSTGRES_DB=n8n_alcore
POSTGRES_USER=alcore
POSTGRES_PASSWORD=alcore_local_123
# Puerto en tu computadora. Dentro de Docker PostgreSQL sigue usando 5432.
POSTGRES_PORT=5433

# n8n local
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678/
WEBHOOK_URL=http://localhost:5678/
N8N_SECURE_COOKIE=false

# Cambia este valor si vas a conservar credenciales reales en n8n.
# Debe mantenerse igual entre reinicios para no perder acceso a credenciales guardadas.
N8N_ENCRYPTION_KEY=alcore-local-dev-key-change-32chars

# API Node.js de prueba
NODE_ENV=development
NODE_APP_PORT=3000
APP_NAME=alcore-node-app

# ngrok es opcional.
# Crea un token gratis en https://dashboard.ngrok.com/get-started/your-authtoken
# Luego ejecuta: docker compose --profile tunnel up -d
NGROK_AUTHTOKEN=CAMBIAR_POR_TU_TOKEN_GRATUITO_DE_NGROK
